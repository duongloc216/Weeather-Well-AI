# ================================
# DATABASE - SQL SERVER
# ================================
DB_TYPE=sqlserver
SQL_SERVER_HOST=localhost\MSSQLSERVER02
SQL_SERVER_PORT=1433
SQL_SERVER_DATABASE=WeatherWell_AI
SQL_SERVER_USER=your_user
SQL_SERVER_PASSWORD=your_password
SQL_SERVER_DRIVER=ODBC Driver 17 for SQL Server

# ================================
# REDIS CONFIGURATION
# ================================
REDIS_DATA_HOST=localhost
REDIS_QUEUE_PORT=6379

# ================================
# CHROMADB CONFIGURATION
# ================================
CHROMA_SERVER_HOST=localhost
CHROMA_SERVER_PORT=8001

# ================================
# QUEUE NAMES
# ================================
QUEUE_DATA=queue_data
QUEUE_CHATBOT=queue_chatbot
QUEUE_PASSIVE_SUGGESTION=queue_passive_suggestion

# ================================
# EXTERNAL APIs
# ================================
# OpenWeather API Keys (đăng ký tại https://openweathermap.org/api)
OPEN_WEATHER_API=your_openweather_api_key

# API Retry Configuration
BASE_BACKOFF=1.0
MAX_RETRY=5

# ================================
# LOCAL AI MODELS (không cần API keys)
# ================================
# Embedding Model: paraphrase-multilingual-mpnet-base-v2 (768D)
# LLM Model: Qwen2.5-3B-Instruct-Q4_K_M.gguf (2.0GB)

# ================================
# JWT SECRET
# ================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
